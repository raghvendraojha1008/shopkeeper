{
  "name": "shopkeeper-functions",
  "description": "Firebase Cloud Functions for Shopkeeper payment system",
  "scripts": {
    "build":  "tsc",
    "watch":  "tsc --watch",
    "serve":  "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "logs":   "firebase functions:log"
  },
  "engines":  { "node": "20" },
  "main":     "lib/index.js",
  "dependencies": {
    "firebase-admin":     "^13.0.0",
    "firebase-functions": "^6.0.0",
    "razorpay":           "^2.9.4"
  },
  "devDependencies": {
    "@types/node":          "^20.0.0",
    "typescript":           "^5.4.0"
  },
  "private": true
}
